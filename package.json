{
  "name": "mcp-bastion",
  "version": "0.6.0",
  "description": "Reliability + security proxy for the Model Context Protocol (MCP): self-healing connections, runtime tool-security (rug-pull/poisoning detection), and a compliance-mapped audit trail.",
  "type": "module",
  "bin": {
    "mcp-bastion": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npm run build && node scripts/demo.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-proxy",
    "mcp-gateway",
    "mcp-security",
    "proxy",
    "gateway",
    "ai",
    "llm",
    "agent",
    "agentic",
    "ai-security",
    "llm-security",
    "security",
    "guardrails",
    "reliability",
    "reconnect",
    "audit",
    "audit-log",
    "observability",
    "compliance",
    "nist-ai-rmf",
    "owasp",
    "tool-poisoning"
  ],
  "license": "Apache-2.0",
  "author": "mcp-bastion contributors",
  "homepage": "https://github.com/Gowthaman90/mcp-bastion#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gowthaman90/mcp-bastion.git"
  },
  "bugs": {
    "url": "https://github.com/Gowthaman90/mcp-bastion/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.8"
  }
}
